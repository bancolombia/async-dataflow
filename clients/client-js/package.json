{
  "name": "@bancolombia/chanjs-client",
  "version": "1.0.0",
  "description": "AsycnDataflow websocket browser client. By Bancolombia",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "browser": {
        "import": "./dist/esm/index.js",
        "require": "./dist/cjs/index.js"
      },
      "node": {
        "import": "./dist/esm/index.js",
        "require": "./dist/cjs/index.js"
      },
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "nyc mocha --reporter spec --reporter mocha-sonarqube-reporter --reporter-options output=coverage/xunit.xml --require source-map-support/register --require jsdom-global/register --require ts-node/register --require ./test/setup-resolver.cjs 'test/**/*.test.ts'",
    "test-local": "mocha --require jsdom-global/register --require source-map-support/register --require ts-node/register --require ./test/setup-resolver.cjs 'test/**/*.test.ts'",
    "watch:build": "tsc -p tsconfig.esm.json --watch",
    "sonar-scanner": "node_modules/sonar-scanner/bin/sonar-scanner",
    "prepare": "npm run build",
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && node scripts/fixup-dist.js",
    "publish-local": "npm unpublish --registry http://localhost:4873 && npm run build && npm publish --registry http://localhost:4873 && echo 'Deployed!'",
    "lint": "eslint --ext .ts ."
  },
  "nyc": {
    "extension": [
      ".ts",
      ".tsx"
    ],
    "exclude": [
      "**/*.d.ts",
      "coverage",
      "dist",
      "src/index.ts",
      "**/*.d.ts",
      "**/*.test.ts"
    ],
    "reporter": [
      "lcov"
    ],
    "all": true
  },
  "keywords": [
    "async",
    "notifications",
    "websocket"
  ],
  "author": "Daniel Bustamante Ospina <danibust@bancolombia.com.co>",
  "repository": {
    "type": "git",
    "url": "https://github.com/bancolombia/async-dataflow"
  },
  "license": "ISC",
  "devDependencies": {
    "@types/chai": "^4.1.6",
    "@types/mocha": "^5.2.5",
    "@types/sinon": "^5.0.3",
    "@typescript-eslint/eslint-plugin": "^6.7.2",
    "@typescript-eslint/parser": "^6.7.2",
    "chai": "^4.2.0",
    "deps": "^1.0.0",
    "eslint": "^8.49.0",
    "fast-check": "^4.7.0",
    "fast-text-encoding": "^1.0.3",
    "jsdom": "22.1.0",
    "jsdom-global": "3.0.2",
    "mocha": "^11.1.0",
    "mocha-sonarqube-reporter": "^1.0.2",
    "mock-socket": "^9.0.6",
    "node-fetch": "^2.6.1",
    "nyc": "^15.1.0",
    "rxjs": "^7.8.1",
    "sinon": "^6.3.5",
    "sonar-scanner": "^3.1.0",
    "source-map-support": "^0.5.9",
    "ts-mock-imports": "^1.2.1",
    "ts-mockito": "^2.3.1",
    "ts-node": "^7.0.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "event-source-plus": "^0.1.8",
    "lru-cache": "^11.0.2",
    "undici": "^7.3.0"
  },
  "overrides": {
    "minimatch": "5.1.2",
    "glob": "8.1.0"
  }
}
