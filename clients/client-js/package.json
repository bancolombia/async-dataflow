{
  "name": "@bancolombia/chanjs-client",
  "version": "1.0.0",
  "description": "AsycnDataflow websocket browser client. By Bancolombia",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "browser": {
        "import": "./dist/esm/index.js",
        "require": "./dist/cjs/index.js"
      },
      "node": {
        "import": "./dist/esm/index.js",
        "require": "./dist/cjs/index.js"
      },
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "TSX_TSCONFIG_PATH=tsconfig.test.json NODE_OPTIONS='--import tsx' c8 mocha --reporter spec --require ./test/setup-cjs-requires.cjs --require ./test/setup-resolver.cjs 'test/**/*.test.ts'",
    "test-local": "TSX_TSCONFIG_PATH=tsconfig.test.json NODE_OPTIONS='--import tsx' mocha --require ./test/setup-cjs-requires.cjs --require ./test/setup-resolver.cjs 'test/**/*.test.ts'",
    "watch:build": "tsc -p tsconfig.esm.json --watch",
    "sonar-scanner": "node_modules/sonar-scanner/bin/sonar-scanner",
    "prepare": "npm run build",
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && node scripts/fixup-dist.js",
    "publish-local": "npm unpublish --registry http://localhost:4873 && npm run build && npm publish --registry http://localhost:4873 && echo 'Deployed!'",
    "lint": "eslint --ext .ts ."
  },
  "keywords": [
    "async",
    "notifications",
    "websocket"
  ],
  "author": "Daniel Bustamante Ospina <danibust@bancolombia.com.co>",
  "repository": {
    "type": "git",
    "url": "https://github.com/bancolombia/async-dataflow"
  },
  "license": "ISC",
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/sinon": "^21.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "deps": "^1.0.0",
    "eslint": "^10.3.0",
    "fast-check": "^4.7.0",
    "fast-text-encoding": "^1.0.6",
    "jsdom": "^29.1.1",
    "jsdom-global": "^3.0.2",
    "mocha": "^11.3.0",
    "mocha-sonarqube-reporter": "^1.0.2",
    "mock-socket": "^9.3.1",
    "node-fetch": "^3.3.2",
    "rxjs": "^7.8.2",
    "sinon": "^22.0.0",
    "sonar-scanner": "^3.1.0",
    "source-map-support": "^0.5.21",
    "ts-mock-imports": "^1.3.19",
    "ts-mockito": "^2.6.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "event-source-plus": "^0.1.15",
    "lru-cache": "^11.3.6",
    "undici": "^8.2.0"
  },
  "overrides": {
    "minimatch": "^10.2.5",
    "glob": "^13.0.6"
  }
}
