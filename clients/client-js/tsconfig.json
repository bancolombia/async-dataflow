{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "paths": { "*": ["types/*"] },
    "target": "es2020",
    "declaration": true,
    "sourceMap": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "test"
  ]
}
